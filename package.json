    "stripe": "^18.5.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2",
    "pptxgenjs": "^4.0.1",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.2.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
