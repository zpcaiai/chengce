DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chengce"
AUTH_SECRET="replace-this-with-a-long-random-value"
DEV_USER_ID="usr_local"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
AI_PROVIDER="mock"
UPLOAD_DIR="./uploads"
# Optional: enables audio transcription in the file-upload workflow.
# OPENAI_TRANSCRIBE_MODEL="gpt-4o-mini-transcribe"
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# Stripe production subscription billing (server-only values)
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_PRICE_DIAGNOSTIC="price_..."
# STRIPE_PRICE_DELIVERY="price_..."
# STRIPE_PRICE_CONTINUITY="price_..."

# ── Vercel 部署 ──
# 用 Vercel Postgres / Neon 等集成后会自动注入 DATABASE_URL。
# 至少需在 Project Settings → Environment Variables 配置：
#   DATABASE_URL（数据库连接串）、AUTH_SECRET（随机长字符串）、NEXT_PUBLIC_APP_URL（线上域名）
# 构建会自动执行：prisma generate → prisma db push（建表）→ prisma db seed（初始化数据）→ next build

# ── 邀请邮件（SendGrid，可选）──
# 配置后，生成邀请会自动发送邀请邮件；未配置则只返回邀请链接由你手动转发。
# SENDGRID_API_KEY="SG.xxxxx"
# EMAIL_FROM="invites@your-domain.com"   # 需在 SendGrid 完成发件域名/单发件人验证
# EMAIL_FROM_NAME="承策 Chengce"

# ── 定时任务（通知中心扫描 / 自动复诊）──
# Vercel Cron 每天调用 /api/cron/sweep，用该密钥鉴权（Vercel 会自动带 Authorization: Bearer）。
# CRON_SECRET="一个随机长字符串"

# ── Slack 出站通知（可选）──
# 配置 Incoming Webhook 后，生成月报/完整诊断/决策复盘会推送到 Slack。
# SLACK_WEBHOOK_URL="https://hooks.slack.com/services/XXX/YYY/ZZZ"
# OPENAI_EMBED_MODEL="text-embedding-3-small"   # 语义检索嵌入模型（可选）

# ── 企业级（可选）──
# 品牌化客户门户无需额外配置（在工作区设置里填品牌名/Logo/主色）。
# 报告导出 PPT/Excel 依赖 pptxgenjs / exceljs（已在 dependencies，npm install 即可）。
# SSO/SCIM 需外部 IdP（脚手架已预留 src/lib/sso.ts）：
# SSO_ISSUER=""
# SSO_CLIENT_ID=""
# SSO_CLIENT_SECRET=""
